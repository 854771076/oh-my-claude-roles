{
  "name": "推送前全量测试与安全扫描",
  "description": "推送到远程仓库前执行全量单元测试与安全扫描，不通过禁止推送",
  "triggers": ["PrePush"],
  "matcher": "**/*",
  "hooks": [
    {
      "type": "command",
      "command": "npx vitest run --coverage",
      "timeout": 600
    },
    {
      "type": "command",
      "command": "npm run security-scan",
      "timeout": 120
    }
  ]
}