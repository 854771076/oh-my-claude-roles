{
  "name": "vue3-pre-commit-secret-check",
  "description": "检查提交代码中是否包含敏感信息硬编码",
  "triggers": ["PreCommit"],
  "matcher": "*",
  "hooks": [
    {
      "type": "command",
      "command": "grep -r \"AKIA\\|secret\\|password\\|token\\|key\" --include=\"*.ts\" --include=\"*.vue\" --include=\"*.js\" src/ | grep -v \"node_modules\" | grep -v \".d.ts\" || true",
      "timeout": 60
    }
  ]
}