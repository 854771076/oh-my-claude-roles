{
  "name": "敏感信息扫描检查",
  "description": "扫描代码中是否包含密码、密钥、Token等敏感信息，防止提交敏感数据",
  "triggers": ["PreCommit"],
  "hooks": [
    {
      "type": "command",
      "command": "grep -r -E '(password|secret|key|token|api_key|access_key|private_key) *= *[\"'][^\"']{10,}[\"']' --include=\"*.py\" --include=\"*.env\" --exclude-dir=venv --exclude-dir=__pycache__ . || exit 0",
      "timeout": 30
    }
  ]
}